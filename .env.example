# Frontend public URL (this app)
VITE_FE_URL=http://localhost:5173

# Backend base URL — browser calls {VITE_BE_URL}/api in dev and production
# Local:       http://localhost:3001
# Production:  https://toolhub-be.vercel.app
VITE_BE_URL=http://localhost:3001

# Optional override for the full API base URL (defaults to {VITE_BE_URL}/api)
# VITE_API_URL=http://localhost:3001/api
