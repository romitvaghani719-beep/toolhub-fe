# Frontend public URL (this app)
VITE_FE_URL=http://localhost:5173

# Backend API base URL (used by Vite dev proxy)
VITE_BE_URL=http://localhost:3001

# API path the browser calls
# Local (proxy):  /api
# Production same domain: /api
# Production separate API domain: https://api.yourdomain.com
VITE_API_URL=/api

# Backend base URL (used as production fallback when VITE_API_URL is not set)
# Example: https://toolhub-be.vercel.app
# VITE_BE_URL=
